# ==============================================
# Retech Auth API — variáveis de ambiente
# ==============================================

# ==============================================
# SERVIDOR
# ==============================================
PORT=8000
ENV=development

# ==============================================
# BANCO DE DADOS
# ==============================================
DB_HOST=localhost
DB_PORT=5430
DB_USER=retech_auth_user
DB_PASSWORD=4b4a8b44-6860-4bf6-827c-9b50f2fbbc89
DB_NAME=retech_auth_db
DB_SSLMODE=disable

# Variáveis auxiliares PostgreSQL (usadas pelo docker-compose)
CONTAINER_NAME=retech-auth-db
PGHOST=localhost
PGUSER=retech_auth_user
PGPASSWORD=4b4a8b44-6860-4bf6-827c-9b50f2fbbc89
PGDATABASE=retech_auth_db
PGPORT=5430
PGDATA=/var/lib/postgresql/data/pgdata
PGVOLUME_NAME=retech_auth_db_volume
COMPOSE_NETWORK=retech-network

# ==============================================
# JWT (AUTENTICAÇÃO)
# ==============================================
# Diretório para chaves RSA (geradas na primeira execução)
# Em produção, use um caminho seguro (ex: /var/lib/retechauth/keys)
JWT_RSA_KEYS_DIR=./keys
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_HOURS=168

# ==============================================
# BOOTSTRAP SECRET (CRIAÇÃO INICIAL / SYNC HMAC)
# ==============================================
# Secret compartilhado para /applications/sync via HMAC (bootstrap).
# Ferramentas e CLIs podem usar RETECHAUTH_BOOTSTRAP_SECRET com o mesmo valor.
# Gere um secret seguro: openssl rand -base64 32
# O HMAC existe para criar ou sincronizar a primeira aplicação (manifest) 
# quando ainda não há token (por exemplo, pipeline/CLI que publica o manifest antes de existir login naquela app).
# Quem chama precisa conhecer o mesmo valor (na documentação OpenAPI isso aparece como sugestão de variável
# no cliente, ex. RETECHAUTH_BOOTSTRAP_SECRET — é só o mesmo segredo, o nome no cliente é convenção).
BOOTSTRAP_SECRET=your-bootstrap-secret-here

# ==============================================
# CORS
# ==============================================
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ==============================================
# DOCUMENTAÇÃO — Redoc
# ==============================================
DOCS_ENABLED=true
DOCS_SPEC_URL=/public/openapi-v1.yaml
DOCS_TITLE=Retech Auth API
DOCS_DESCRIPTION=Documentação dos serviços de autenticação e autorização Retech.
DOCS_VERSION=v1 (1.0.0)
DOCS_API_BASE_URL=http://localhost:8000/v1
DOCS_VERSION_LINKS=v1:/docs/v1
DOCS_HERO_SUPPORT_EMAIL=suporte@theretech.com.br
DOCS_HERO_SUPPORT_URL=https://theretech.com.br
DOCS_HERO_LICENSE=Proprietary
