							"mode": "raw",
							"raw": "{\n  \"application\": {\n    \"code\": \"{{applicationCode}}\",\n    \"name\": \"App Sync\",\n    \"description\": \"Manifest mínimo\"\n  },\n  \"permissions\": [\n    {\n      \"code\": \"app.example.view\",\n      \"description\": \"Exemplo\",\n      \"subject\": \"Example\",\n      \"action\": \"view\"\n    }\n  ],\n  \"roles\": [\n    {\n      \"code\": \"admin.example\",\n      \"name\": \"Admin Example\",\n      \"system\": false,\n      \"description\": \"\",\n      \"permissions\": [\"app.example.view\"]\n    }\n  ]\n}"
						},
						"url": "{{baseUrlDev}}/v1/applications/sync",
						"description": "Também aceita HMAC: headers `X-Signature` + `X-Timestamp` e body bruto assinado com `BOOTSTRAP_SECRET` (ver middleware sync)."
