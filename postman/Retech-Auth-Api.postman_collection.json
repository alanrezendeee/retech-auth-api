		{
			"name": "Auth (público)",
			"item": [
				{
					"name": "POST /v1/authenticate",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"{{authEmail}}\",\n  \"password\": \"{{authPassword}}\",\n  \"application_code\": \"{{applicationCode}}\"\n}"
						},
						"url": "{{baseUrlDev}}/v1/authenticate",
						"description": "Resposta inclui `access_token` e `refresh_token`. Copie para as variáveis da coleção."
					},
					"response": []
				},
				{
					"name": "POST /v1/account/authenticate (alias)",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"{{authEmail}}\",\n  \"password\": \"{{authPassword}}\",\n  \"application_code\": \"{{applicationCode}}\"\n}"
						},
						"url": "{{baseUrlDev}}/v1/account/authenticate"
					},
					"response": []
				},
